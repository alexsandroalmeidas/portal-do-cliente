{
  "name": "portal-do-cliente",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start-uat": "ng serve --configuration uat",
    "start-ssl": "ng serve --ssl --ssl-key localhost.key --ssl-cert localhost.crt",
    "build": "ng build",
    "build-uat": "ng build --configuration uat",
    "build-prod": "rm -rf dist ng build --configuration production --no-webpack --aot --output-hashing=all && mv dist/portal-do-cliente/assets/web.config dist/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "clean": "rm -rf node_modules && rm -f package-lock.json",
    "setup": "npm run clean && node --max-old-space-size=8000 $(which npm) install --force",
    "pm2": "pm2 serve /dist/portal-do-cliente --no-daemon --spa",
    "ng-high-memory": "node --max_old_space_size=8000 ./node_modules/@angular/cli/bin/ng serve"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~15.2.9",
    "@angular/cdk": "~15.2.9",
    "@angular/common": "~15.2.9",
